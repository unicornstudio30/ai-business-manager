# ─────────────────────────────────────────────────────────────────
# Database — Turso (libsql)
# Get these at https://app.turso.tech after creating a database.
# Locally you can leave both blank to use a file-based SQLite at ./data/app.db
# ─────────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Notion integration token
# Create at https://www.notion.so/profile/integrations
# Then in Notion, share the 3 databases with the integration:
#   - Unicorn Studio's Sales CRM
#   - Unicorn Studio's Sales tracker
#   - Unicorn Studio Content Calendar
# Click ··· in each database → Add connections → select your integration.
# ─────────────────────────────────────────────────────────────────
NOTION_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Auth — HTTP basic auth (single username + password)
# Leave APP_PASSWORD blank locally to skip auth entirely.
# In production, set both. Browser will prompt once per session.
# ─────────────────────────────────────────────────────────────────
APP_USERNAME=saidur
APP_PASSWORD=

# ─────────────────────────────────────────────────────────────────
# Claude Code slash command shared secret
# Slash commands send this in x-claude-api-key header to bypass basic auth.
# Run: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Base URL the slash commands hit.
# Local: http://localhost:3000  Prod: https://your-app.vercel.app
# ─────────────────────────────────────────────────────────────────
APP_URL=

# ─────────────────────────────────────────────────────────────────
# Google Calendar — secret ICS feed URL
# In Google Calendar:
#   Settings → Integrate calendar (under your specific calendar)
#   → Secret address in iCal format → copy
# Read-only. Free. ~24h sync delay possible.
# ─────────────────────────────────────────────────────────────────
GCAL_ICS_URL=

# ─────────────────────────────────────────────────────────────────
# (Future) Buffer Essentials API token — for post performance metrics
# Get at https://buffer.com/developers/apps once you upgrade
# ─────────────────────────────────────────────────────────────────
BUFFER_TOKEN=
