# ─────────────────────────────────────────────────────────────────
# Database — Turso (libsql)
# Get these at https://app.turso.tech after creating a database.
# Locally you can leave both blank to use a file-based SQLite at ./data/app.db
# ─────────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Notion integration token
# Create at https://www.notion.so/profile/integrations
# Then in Notion, share the 3 databases with the integration:
#   - Unicorn Studio's Sales CRM
#   - Unicorn Studio's Sales tracker
#   - Unicorn Studio Content Calendar
# ─────────────────────────────────────────────────────────────────
NOTION_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Auth — NextAuth v5 with Google
# Get credentials at https://console.cloud.google.com → OAuth 2.0 Client IDs
# AUTH_SECRET: any random string (run `openssl rand -base64 32`)
# ALLOWED_EMAILS: comma-separated list of Google accounts allowed to sign in.
# Leave empty during local dev to allow any Google sign-in.
# ─────────────────────────────────────────────────────────────────
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

# ─────────────────────────────────────────────────────────────────
# Claude Code slash command auth
# Set CLAUDE_API_KEY to a random string. Slash commands send this
# in the x-claude-api-key header to bypass session auth.
# Run: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Base URL the slash commands use to hit the API.
# Local: http://localhost:3000
# Prod:  https://your-app.vercel.app
# ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# AUTH_URL is needed in production for NextAuth to know the host.
# Local: omit (auto-detected). Vercel: set to https://your-app.vercel.app
# ─────────────────────────────────────────────────────────────────
AUTH_URL=
